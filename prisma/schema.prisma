generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TransactionSource {
  CSV
  BANK_API
  RECEIPT
  MANUAL
}

enum BudgetPeriod {
  MONTHLY
  WEEKLY
}

enum SubscriptionFrequency {
  MONTHLY
  WEEKLY
  ANNUAL
}

enum AnomalySeverity {
  LOW
  MEDIUM
  HIGH
}

enum ChatRole {
  USER
  ASSISTANT
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String
  name      String?
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions  Transaction[]
  budgets       Budget[]
  subscriptions Subscription[]
  anomalyFlags  AnomalyFlag[]
  memory        UserMemory?
  chatMessages  ChatMessage[]

  @@map("users")
}

model Transaction {
  id          String            @id @default(cuid())
  userId      String
  date        DateTime
  amount      Decimal           @db.Decimal(12, 2)
  merchant    String
  category    String?
  description String?
  source      TransactionSource @default(MANUAL)
  rawData     Json?
  isDuplicate Boolean           @default(false)
  createdAt   DateTime          @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  anomalyFlags AnomalyFlag[]

  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, merchant])
  @@map("transactions")
}

model Budget {
  id          String       @id @default(cuid())
  userId      String
  category    String
  limitAmount Decimal      @db.Decimal(12, 2)
  period      BudgetPeriod @default(MONTHLY)
  startDate   DateTime     @default(now())
  createdAt   DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, period])
  @@index([userId])
  @@map("budgets")
}

model Subscription {
  id         String                @id @default(cuid())
  userId     String
  merchant   String
  amount     Decimal               @db.Decimal(12, 2)
  frequency  SubscriptionFrequency @default(MONTHLY)
  lastSeen   DateTime
  isActive   Boolean               @default(true)
  detectedAt DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchant])
  @@index([userId, isActive])
  @@map("subscriptions")
}

model AnomalyFlag {
  id            String          @id @default(cuid())
  userId        String
  transactionId String
  reason        String
  severity      AnomalySeverity @default(LOW)
  seenByUser    Boolean         @default(false)
  createdAt     DateTime        @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId])
  @@index([userId, seenByUser])
  @@map("anomaly_flags")
}

model UserMemory {
  id          String   @id @default(cuid())
  userId      String   @unique
  preferences Json     @default("{}")
  lastUpdated DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_memory")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      ChatRole
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}